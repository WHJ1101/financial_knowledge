# Financial Knowledge 环境变量模板
FINANCE_KNOWLEDGE_LLM_API_KEY=your-api-key-here
FINANCE_KNOWLEDGE_LLM_API_URL=https://openrouter.ai/api/v1/chat/completions
FINANCE_KNOWLEDGE_LLM_MODEL=openai/gpt-4o-mini

# 云端部署建议开启登录。未设置密码时，本地开发默认不启用登录。
FINANCE_KNOWLEDGE_AUTH_REQUIRED=true
FINANCE_KNOWLEDGE_AUTH_USERNAME=admin
FINANCE_KNOWLEDGE_AUTH_PASSWORD=change-me
FINANCE_KNOWLEDGE_AUTH_SECRET=replace-with-a-long-random-string

# Codex/脚本显式导入报告时使用，不等同于登录密码。
FINANCE_KNOWLEDGE_IMPORT_TOKEN=replace-with-another-long-random-token

# Docker/云端持久化数据目录。
FINANCE_KNOWLEDGE_DATA_DIR=/app/data
